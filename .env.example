# Deployment used by `bunx convex dev`
CONVEX_DEPLOYMENT=your-convex-deployment

PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key
PUBLIC_CONVEX_URL=https://your-team.convex.cloud
CLERK_SECRET_KEY=your-clerk-secret-key
CLERK_JWT_ISSUER_DOMAIN=https://your-clerk-domain.clerk.accounts.dev
PUBLIC_CLERK_SIGN_IN_URL=/login
PUBLIC_CLERK_SIGN_UP_URL=/login
PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/scanner
PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/scanner

DATABASE_URL=file:./local.db
DATABASE_AUTH_TOKEN=your-database-auth-token
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

MASSIVE_API_KEY=your-massive-api-key

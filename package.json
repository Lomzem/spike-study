{
  "name": "spike-study",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "packageManager": "bun@1.3.11",
  "scripts": {
    "dev": "bunx convex dev --once && concurrently -r \"bun run dev:web\" \"bun run dev:convex\"",
    "dev:web": "vite dev",
    "dev:convex": "bunx convex dev",
    "build": "vite build && bun run check",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo '' && husky",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint . && bun run check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "job:backfill-gaps": "bun run src/jobs/backfillGaps.ts",
    "job:fetch-daily": "bun run src/jobs/fetchDailyStocks.ts",
    "job:fetch-intraday": "bun run src/jobs/fetchIntradayStock.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "clsx": "^2.1.1",
    "convex": "^1.31.7",
    "convex-helpers": "^0.1.111",
    "convex-svelte": "^0.0.12",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.2",
    "lightweight-charts": "^5.1.0",
    "svelte-clerk": "^1.1.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@convex-dev/eslint-plugin": "^1.1.1",
    "@eslint/compat": "^2.0.4",
    "@eslint/js": "^10.0.1",
    "@internationalized/date": "^3.12.0",
    "@lucide/svelte": "^1.8.0",
    "@sveltejs/adapter-vercel": "^6.3.3",
    "@sveltejs/kit": "^2.57.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.10.10",
    "bits-ui": "^2.16.3",
    "concurrently": "~9.2.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "shadcn-svelte": "^1.2.7",
    "svelte": "^5.55.2",
    "svelte-check": "^4.4.6",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.7"
  },
  "lint-staged": {
    "*": "prettier --ignore-unknown --write"
  }
}
